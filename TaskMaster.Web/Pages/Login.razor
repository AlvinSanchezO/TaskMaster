@page "/login"
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.WebUtilities
@inject HttpClient Http
@inject ILocalStorageService localStorage
@inject NavigationManager Navigation


<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="text-center">Iniciar Sesión</h3>

            @if (showSuccessMessage)
            {
                <div class="alert alert-success border-0 text-center">
                    🎉 ¡Registro exitoso! Ya puedes entrar.
                </div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <div class="mb-3">
                    <label>Usuario</label>
                    <InputText @bind-Value="loginModel.Username" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Contraseña</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <button type="submit" class="btn btn-primary w-100">Entrar</button>

                <div class="mt-4 text-center">
                    <span class="text-muted">¿Eres nuevo aquí?</span>
                    <a href="/register" class="fw-bold text-primary">Crea una cuenta gratis</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool showSuccessMessage = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        // Ahora QueryHelpers será reconocido correctamente
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("registered", out var value))
        {
            showSuccessMessage = value == "true";
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        showSuccessMessage = false;

        var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if (result != null)
            {
                await localStorage.SetItemAsync("authToken", result.Token);
                Navigation.NavigateTo("/tasks");
            }
        }
        else
        {
            errorMessage = "Credenciales incorrectas. Intenta de nuevo.";
        }
    }

    public class LoginRequest { public string Username { get; set; } = ""; public string Password { get; set; } = ""; }
    public class LoginResponse { public string Token { get; set; } = ""; }
}