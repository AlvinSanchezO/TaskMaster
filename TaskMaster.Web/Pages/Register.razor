@page "/register"
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center">Crear Cuenta</h3>
                    <hr />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Usuario</label>
                        <input @bind="regModel.Username" class="form-control" placeholder="Elige un nombre" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" @bind="regModel.Password" class="form-control" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <button @onclick="HandleRegister" class="btn btn-success w-100">Registrarse</button>

                    <div class="mt-3 text-center">
                        <a href="/login">¿Ya tienes cuenta? Inicia sesión</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest regModel = new();
    private string? errorMessage;

    private async Task HandleRegister()
    {
        // Validación básica
        if (string.IsNullOrWhiteSpace(regModel.Username) || string.IsNullOrWhiteSpace(regModel.Password))
        {
            errorMessage = "Todos los campos son obligatorios.";
            return;
        }

        var response = await Http.PostAsJsonAsync("api/auth/register", regModel);

        if (response.IsSuccessStatusCode)
        {
            // Redirección elegante
            Navigation.NavigateTo("/login?registered=true");
        }
        else
        {
            errorMessage = "Error al registrar. El usuario podría ya existir.";
        }
    }

    public class RegisterRequest
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}